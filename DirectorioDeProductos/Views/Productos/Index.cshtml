@model List<DirectorioDeProductos.Models.Producto>

<h2>Directorio de Productos</h2>

<a asp-action="Crear" class="btn btn-primary">Nuevo Producto</a>

<br />
<br />

@if (!Model.Any())
{
    <p>No hay productos registrados.</p>
}
else
{
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nombre</th>
                <th>Precio</th>
                <th>Categoría</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.Nombre</td>
                    <td>@p.Precio.ToString("C")</td>
                    <td>@p.Categoria</td>
                    <td>
                        <a asp-action="Detalles" asp-route-id="@p.Id">Detalles</a> |
                        <a asp-action="Editar" asp-route-id="@p.Id">Editar</a> |
                        <a asp-action="Eliminar" asp-route-id="@p.Id">Eliminar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}